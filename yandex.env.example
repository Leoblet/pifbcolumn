# Yandex SpeechKit — двуязычная колонка (русский + казахский)
# Голоса Сауле: saule_ru (ru-RU), saule (kk-KZ)

VC_STT_ENGINE=yandex
VC_TTS_ENGINE=yandex
VC_YANDEX_TTS_API=v3
VC_LANG_MODE=bilingual
VC_DEFAULT_LANG=ru

VC_YANDEX_API_KEY=AQVNxxxxxxxxxxxxxxxx
VC_YANDEX_FOLDER_ID=b1gxxxxxxxxxxxxxxxx

# TTS — Сауле
VC_YANDEX_VOICE_RU=saule_ru
VC_YANDEX_ROLE_RU=neutral
VC_YANDEX_VOICE_KK=saule
VC_YANDEX_ROLE_KK=neutral
VC_YANDEX_TTS_SPEED=1.0

# STT: bilingual = параллельно ru-RU + kk-KZ; ru | kk = только один язык
# VC_LANG_MODE=ru
# VC_LANG_MODE=kk
